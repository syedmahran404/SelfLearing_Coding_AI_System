# ───── Self-Learning Coding AI · environment template ─────
# Copy to `.env` for local development. Never commit real secrets.

# ── Application ──
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_DEBUG=true
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── LLM provider ──
# Supported: openai | anthropic | local
LLM_PROVIDER=openai
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_PLANNER_MODEL=gpt-4o-mini
LLM_CODER_MODEL=gpt-4o
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_MAX_TOKENS_PER_TASK=120000
LLM_MAX_TOKENS_PER_SESSION=1000000
LLM_REQUEST_TIMEOUT_S=120

OPENAI_API_KEY=
OPENAI_BASE_URL=

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# ── Postgres ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=slcai
POSTGRES_USER=slcai
POSTGRES_PASSWORD=slcai_dev_password
DATABASE_URL=postgresql+asyncpg://slcai:slcai_dev_password@postgres:5432/slcai

# ── Redis ──
REDIS_URL=redis://redis:6379/0
REDIS_SHORT_TERM_TTL_S=3600
REDIS_TOKEN_BUDGET_TTL_S=900

# ── Qdrant (vector store) ──
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_MEMORIES=slcai_memories
QDRANT_COLLECTION_RAG=slcai_rag
QDRANT_VECTOR_SIZE=1536

# ── Sandbox / tools ──
SANDBOX_ROOT=/tmp/slcai_sandbox
SANDBOX_DEFAULT_TIMEOUT_S=30
SANDBOX_MAX_MEMORY_MB=512
SANDBOX_MAX_CPU_S=20
SANDBOX_NETWORK_DEFAULT=deny

# ── Safety ──
SAFETY_MAX_RECURSION_DEPTH=4
SAFETY_MIN_CONFIDENCE_TO_EXECUTE=0.55
SAFETY_HALLUCINATION_BLOCK=true
SAFETY_DRYRUN_FILE_WRITES=false

# ── Memory lifecycle ──
MEMORY_DEDUP_SIM_THRESHOLD=0.95
MEMORY_DECAY_HALFLIFE_DAYS=30
MEMORY_LIFECYCLE_INTERVAL_S=3600

# ── Observability ──
OBSERVABILITY_TRACE_TO_DB=true
OBSERVABILITY_TRACE_TO_STDOUT=true
